},{"cell_type":"markdown","source":"# **Step 4 — Dataset Information**","metadata":{}},{"cell_type":"code","source":"print(\"=\" * 60)\nprint(\"Dataset Information\")\nprint(\"=\" * 60)\n\ndf.info()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:45.417633Z","iopub.execute_input":"2026-07-06T06:11:45.418052Z","iopub.status.idle":"2026-07-06T06:11:45.477279Z","shell.execute_reply.started":"2026-07-06T06:11:45.418Z","shell.execute_reply":"2026-07-06T06:11:45.476274Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 5 — Convert Date Columns**","metadata":{}},{"cell_type":"code","source":"df[\"Order Date\"] = pd.to_datetime(df[\"Order Date\"], dayfirst=True)\ndf[\"Ship Date\"] = pd.to_datetime(df[\"Ship Date\"], dayfirst=True)\n\nprint(\"Date columns converted successfully.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:45.478391Z","iopub.execute_input":"2026-07-06T06:11:45.479249Z","iopub.status.idle":"2026-07-06T06:11:45.783902Z","shell.execute_reply.started":"2026-07-06T06:11:45.479216Z","shell.execute_reply":"2026-07-06T06:11:45.783003Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 6 — Data Quality Assessment**","metadata":{}},{"cell_type":"code","source":"# Missing Values\nmissing = pd.DataFrame({\n    \"Missing Values\": df.isnull().sum(),\n    \"Percentage (%)\": round(df.isnull().sum() / len(df) * 100, 2)\n})\n\ndisplay(missing[missing[\"Missing Values\"] > 0].sort_values(\n    by=\"Missing Values\", ascending=False\n))\n\nprint(f\"Duplicate Rows : {df.duplicated().sum():,}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:45.786028Z","iopub.execute_input":"2026-07-06T06:11:45.786447Z","iopub.status.idle":"2026-07-06T06:11:45.985414Z","shell.execute_reply.started":"2026-07-06T06:11:45.786418Z","shell.execute_reply":"2026-07-06T06:11:45.984422Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 7 — Data Cleaning**","metadata":{}},{"cell_type":"code","source":"# Remove Postal Code column\ndf.drop(columns=[\"Postal Code\"], inplace=True)\n\nprint(\"Data cleaning completed successfully.\")\nprint(f\"New Shape: {df.shape}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:45.98655Z","iopub.execute_input":"2026-07-06T06:11:45.987009Z","iopub.status.idle":"2026-07-06T06:11:46.007497Z","shell.execute_reply.started":"2026-07-06T06:11:45.986971Z","shell.execute_reply":"2026-07-06T06:11:46.006383Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 8 — Feature Engineering**","metadata":{}},{"cell_type":"code","source":"# Order Year\ndf[\"Year\"] = df[\"Order Date\"].dt.year\n\n# Order Month\ndf[\"Month\"] = df[\"Order Date\"].dt.month_name()\n\n# Order Quarter\ndf[\"Quarter\"] = df[\"Order Date\"].dt.quarter\n\nprint(\"Feature engineering completed successfully.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:46.008746Z","iopub.execute_input":"2026-07-06T06:11:46.009233Z","iopub.status.idle":"2026-07-06T06:11:46.039969Z","shell.execute_reply.started":"2026-07-06T06:11:46.009194Z","shell.execute_reply":"2026-07-06T06:11:46.038965Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 9 — Business KPIs**\nKey Performance Indicator","metadata":{}},{"cell_type":"code","source":"total_sales = df[\"Sales\"].sum()\ntotal_profit = df[\"Profit\"].sum()\ntotal_orders = df[\"Order ID\"].nunique()\ntotal_customers = df[\"Customer ID\"].nunique()\n\nprint(f\"Total Sales     : ${total_sales:,.2f}\")\nprint(f\"Total Profit    : ${total_profit:,.2f}\")\nprint(f\"Total Orders    : {total_orders:,}\")\nprint(f\"Total Customers : {total_customers:,}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:46.041183Z","iopub.execute_input":"2026-07-06T06:11:46.041464Z","iopub.status.idle":"2026-07-06T06:11:46.062333Z","shell.execute_reply.started":"2026-07-06T06:11:46.041433Z","shell.execute_reply":"2026-07-06T06:11:46.061304Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 10 — Monthly Sales Trend**","metadata":{}},{"cell_type":"code","source":"\n# Monthly Sales Trend\n\n\nmonthly_sales = (\n    df.groupby([\"Year\", \"Month\"])[\"Sales\"]\n      .sum()\n      .reset_index()\n)\n\n# Correct month order\nmonth_order = [\n    \"January\", \"February\", \"March\", \"April\",\n    \"May\", \"June\", \"July\", \"August\",\n    \"September\", \"October\", \"November\", \"December\"\n]\n\nmonthly_sales[\"Month\"] = pd.Categorical(\n    monthly_sales[\"Month\"],\n    categories=month_order,\n    ordered=True\n)\n\nmonthly_sales = monthly_sales.sort_values([\"Year\", \"Month\"])\n\nplt.figure(figsize=(14,5))\n\nplt.plot(\n    range(len(monthly_sales)),\n    monthly_sales[\"Sales\"],\n    marker=\"o\"\n)\n\nplt.xticks(\n    range(len(monthly_sales)),\n    monthly_sales[\"Year\"].astype(str) + \"-\" + monthly_sales[\"Month\"].str[:3],\n    rotation=45\n)\n\nplt.title(\"Monthly Sales Trend\")\nplt.xlabel(\"Month\")\nplt.ylabel(\"Sales\")\n\nplt.grid(alpha=0.3)\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:48.572666Z","iopub.execute_input":"2026-07-06T06:11:48.573039Z","iopub.status.idle":"2026-07-06T06:11:49.076113Z","shell.execute_reply.started":"2026-07-06T06:11:48.573012Z","shell.execute_reply":"2026-07-06T06:11:49.075056Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 11 — Top 10 Products by Sales**","metadata":{}},{"cell_type":"code","source":"\n# Top 10 Products by Sales\n\n\ntop_products = (\n    df.groupby(\"Product Name\")[\"Sales\"]\n      .sum()\n      .sort_values(ascending=False)\n      .head(10)\n)\n\nplt.figure(figsize=(10,6))\n\ntop_products.sort_values().plot(kind=\"barh\")\n\nplt.title(\"Top 10 Products by Sales\")\nplt.xlabel(\"Total Sales\")\nplt.ylabel(\"Product\")\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:49.078035Z","iopub.execute_input":"2026-07-06T06:11:49.078416Z","iopub.status.idle":"2026-07-06T06:11:49.328546Z","shell.execute_reply.started":"2026-07-06T06:11:49.078387Z","shell.execute_reply":"2026-07-06T06:11:49.327494Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 12 — Top 10 Countries by Sales**","metadata":{}},{"cell_type":"code","source":"\n# Top 10 Countries by Sales\n\n\ntop_countries = (\n    df.groupby(\"Country\")[\"Sales\"]\n      .sum()\n      .sort_values(ascending=False)\n      .head(10)\n)\n\nplt.figure(figsize=(10,6))\n\ntop_countries.sort_values().plot(kind=\"barh\")\n\nplt.title(\"Top 10 Countries by Sales\")\nplt.xlabel(\"Total Sales\")\nplt.ylabel(\"Country\")\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:49.329958Z","iopub.execute_input":"2026-07-06T06:11:49.330568Z","iopub.status.idle":"2026-07-06T06:11:49.540463Z","shell.execute_reply.started":"2026-07-06T06:11:49.330537Z","shell.execute_reply":"2026-07-06T06:11:49.539324Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 13 — Category-wise Sales**","metadata":{}},{"cell_type":"code","source":"\n# Category-wise Sales\n\n\ncategory_sales = (\n    df.groupby(\"Category\")[\"Sales\"]\n      .sum()\n      .sort_values(ascending=False)\n)\n\nplt.figure(figsize=(8,5))\n\ncategory_sales.plot(kind=\"bar\")\n\nplt.title(\"Sales by Category\")\nplt.xlabel(\"Category\")\nplt.ylabel(\"Total Sales\")\n\nplt.xticks(rotation=0)\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:49.542356Z","iopub.execute_input":"2026-07-06T06:11:49.542853Z","iopub.status.idle":"2026-07-06T06:11:49.732054Z","shell.execute_reply.started":"2026-07-06T06:11:49.542813Z","shell.execute_reply":"2026-07-06T06:11:49.731018Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 14 — Monthly Profit Trend**","metadata":{}},{"cell_type":"code","source":"\n# Monthly Profit Trend\n\n\nmonthly_profit = (\n    df.groupby([\"Year\", \"Month\"])[\"Profit\"]\n      .sum()\n      .reset_index()\n)\n\nmonth_order = [\n    \"January\",\"February\",\"March\",\"April\",\"May\",\"June\",\n    \"July\",\"August\",\"September\",\"October\",\"November\",\"December\"\n]\n\nmonthly_profit[\"Month\"] = pd.Categorical(\n    monthly_profit[\"Month\"],\n    categories=month_order,\n    ordered=True\n)\n\nmonthly_profit = monthly_profit.sort_values([\"Year\",\"Month\"])\n\nplt.figure(figsize=(14,5))\n\nplt.fill_between(\n    range(len(monthly_profit)),\n    monthly_profit[\"Profit\"],\n    alpha=0.4\n)\n\nplt.plot(\n    range(len(monthly_profit)),\n    monthly_profit[\"Profit\"],\n    marker=\"o\",\n    linewidth=2\n)\n\nplt.xticks(\n    range(len(monthly_profit)),\n    monthly_profit[\"Year\"].astype(str)+\"-\"+monthly_profit[\"Month\"].str[:3],\n    rotation=45\n)\n\nplt.title(\"Monthly Profit Trend\")\nplt.xlabel(\"Month\")\nplt.ylabel(\"Profit\")\n\nplt.grid(alpha=.3)\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:49.733252Z","iopub.execute_input":"2026-07-06T06:11:49.733706Z","iopub.status.idle":"2026-07-06T06:11:50.274353Z","shell.execute_reply.started":"2026-07-06T06:11:49.733669Z","shell.execute_reply":"2026-07-06T06:11:50.273283Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 15 — Sales vs Profit**","metadata":{}},{"cell_type":"code","source":"\n# Sales by Customer Segment\n\n\nsegment_sales = df.groupby(\"Segment\")[\"Sales\"].sum()\n\nplt.figure(figsize=(7,7))\n\nplt.pie(\n    segment_sales,\n    labels=segment_sales.index,\n    autopct=\"%1.1f%%\",\n    startangle=90,\n    wedgeprops={\"edgecolor\":\"white\"}\n)\n\nplt.title(\"Sales Distribution by Customer Segment\")\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:50.275658Z","iopub.execute_input":"2026-07-06T06:11:50.276068Z","iopub.status.idle":"2026-07-06T06:11:50.395188Z","shell.execute_reply.started":"2026-07-06T06:11:50.276029Z","shell.execute_reply":"2026-07-06T06:11:50.394163Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"market_sales = df.groupby(\"Market\")[\"Sales\"].sum()\n\nplt.figure(figsize=(8,8))\n\nplt.pie(\n    market_sales,\n    labels=market_sales.index,\n    autopct=\"%1.1f%%\",\n    startangle=90,\n    wedgeprops={\"edgecolor\":\"white\"}\n)\n\nplt.title(\"Sales Distribution by Market\")\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:50.397727Z","iopub.execute_input":"2026-07-06T06:11:50.398112Z","iopub.status.idle":"2026-07-06T06:11:50.565025Z","shell.execute_reply.started":"2026-07-06T06:11:50.398084Z","shell.execute_reply":"2026-07-06T06:11:50.56399Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 16 — Sales Distribution by Customer Segment**","metadata":{}},{"cell_type":"code","source":"\n# Sales Distribution by Customer Segment\n\n\nsegment_sales = (\n    df.groupby(\"Segment\")[\"Sales\"]\n      .sum()\n      .sort_values(ascending=False)\n)\n\nplt.figure(figsize=(7,7))\n\nplt.pie(\n    segment_sales,\n    labels=segment_sales.index,\n    autopct=\"%1.1f%%\",\n    startangle=90,\n    explode=[0.05, 0.03, 0.02],\n    wedgeprops={\"edgecolor\":\"white\"}\n)\n\nplt.title(\"Sales Distribution by Customer Segment\")\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:50.566291Z","iopub.execute_input":"2026-07-06T06:11:50.566875Z","iopub.status.idle":"2026-07-06T06:11:50.777688Z","shell.execute_reply.started":"2026-07-06T06:11:50.566835Z","shell.execute_reply":"2026-07-06T06:11:50.776711Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Chart 17 — Sales Distribution by Market**","metadata":{}},{"cell_type":"code","source":"\n# Sales Distribution by Market\n\n\nmarket_sales = (\n    df.groupby(\"Market\")[\"Sales\"]\n      .sum()\n      .sort_values(ascending=False)\n)\n\nplt.figure(figsize=(8,8))\n\nplt.pie(\n    market_sales,\n    labels=market_sales.index,\n    autopct=\"%1.1f%%\",\n    startangle=90,\n    wedgeprops={\"edgecolor\":\"white\"}\n)\n\nplt.title(\"Sales Distribution by Market\")\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:11:50.778885Z","iopub.execute_input":"2026-07-06T06:11:50.779325Z","iopub.status.idle":"2026-07-06T06:11:50.933502Z","shell.execute_reply.started":"2026-07-06T06:11:50.77929Z","shell.execute_reply":"2026-07-06T06:11:50.932522Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 18 — Business Insights**","metadata":{}},{"cell_type":"code","source":"\n# Business Insights\n\n\nprint(\"1. The United States generated the highest sales among all countries.\")\n\nprint(\"2. Consumer customers contributed the largest share of total sales.\")\n\nprint(\"3. Technology was the highest-performing product category in terms of sales.\")\n\nprint(\"4. Sales increased over time, showing overall business growth.\")\n\nprint(\"5. The business operates successfully across multiple global markets.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:13:12.760521Z","iopub.execute_input":"2026-07-06T06:13:12.760869Z","iopub.status.idle":"2026-07-06T06:13:12.767463Z","shell.execute_reply.started":"2026-07-06T06:13:12.760841Z","shell.execute_reply":"2026-07-06T06:13:12.765999Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 19 — Business Recommendations**","metadata":{}},{"cell_type":"code","source":"\n# Business Recommendations\n\n\nrecommendations = [\n    \"Increase focus on high-performing Technology products.\",\n    \"Strengthen marketing campaigns for the Consumer segment.\",\n    \"Expand sales efforts in high-performing markets.\",\n    \"Review low-profit categories to improve profitability.\",\n    \"Monitor monthly sales trends for better business planning.\"\n]\n\nfor i, rec in enumerate(recommendations, start=1):\n    print(f\"{i}. {rec}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T06:15:35.339852Z","iopub.execute_input":"2026-07-06T06:15:35.340256Z","iopub.status.idle":"2026-07-06T06:15:35.347859Z","shell.execute_reply.started":"2026-07-06T06:15:35.340224Z","shell.execute_reply":"2026-07-06T06:15:35.346641Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Step 20 — Conclusion**\n\nThis project analyzed the Global Superstore dataset using Python, Pandas, and Matplotlib.\n\nThe data was cleaned, explored, and transformed to generate business KPIs and meaningful visualizations. The analysis identified top-performing products, customer segments, markets, and sales trends.\n\nThis project demonstrates beginner-level data analysis skills, including data cleaning, exploratory data analysis, feature engineering, and business reporting.\n","metadata":{}}]}