 non-null  object \n 17  Product Name    51290 non-null  object \n 18  Sales           51290 non-null  float64\n 19  Quantity        51290 non-null  int64  \n 20  Discount        51290 non-null  float64\n 21  Profit          51290 non-null  float64\n 22  Shipping Cost   51290 non-null  float64\n 23  Order Priority  51290 non-null  object \ndtypes: float64(5), int64(2), object(17)\nmemory usage: 9.4+ MB\n","output_type":"stream"}],"execution_count":13},{"cell_type":"markdown","source":"# **Step 5 — Convert Date Columns**","metadata":{}},{"cell_type":"code","source":"df[\"Order Date\"] = pd.to_datetime(df[\"Order Date\"], dayfirst=True)\ndf[\"Ship Date\"] = pd.to_datetime(df[\"Ship Date\"], dayfirst=True)\n\nprint(\"Date columns converted successfully.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T05:21:28.463732Z","iopub.execute_input":"2026-07-06T05:21:28.464046Z","iopub.status.idle":"2026-07-06T05:21:28.753985Z","shell.execute_reply.started":"2026-07-06T05:21:28.464013Z","shell.execute_reply":"2026-07-06T05:21:28.753027Z"}},"outputs":[{"name":"stdout","text":"Date columns converted successfully.\n","output_type":"stream"}],"execution_count":14},{"cell_type":"markdown","source":"# **Step 6 — Data Quality Assessment**","metadata":{}},{"cell_type":"code","source":"# Missing Values\nmissing = pd.DataFrame({\n    \"Missing Values\": df.isnull().sum(),\n    \"Percentage (%)\": round(df.isnull().sum() / len(df) * 100, 2)\n})\n\ndisplay(missing[missing[\"Missing Values\"] > 0].sort_values(\n    by=\"Missing Values\", ascending=False\n))\n\nprint(f\"Duplicate Rows : {df.duplicated().sum():,}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T05:21:27.807397Z","iopub.execute_input":"2026-07-06T05:21:27.807742Z","iopub.status.idle":"2026-07-06T05:21:27.993902Z","shell.execute_reply.started":"2026-07-06T05:21:27.807708Z","shell.execute_reply":"2026-07-06T05:21:27.993028Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"             Missing Values  Percentage (%)\nPostal Code           41296           80.51","text/html":"<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border=\"1\" class=\"dataframe\">\n  <thead>\n    <tr style=\"text-align: right;\">\n      <th></th>\n      <th>Missing Values</th>\n      <th>Percentage (%)</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>Postal Code</th>\n      <td>41296</td>\n      <td>80.51</td>\n    </tr>\n  </tbody>\n</table>\n</div>"},"metadata":{}},{"name":"stdout","text":"Duplicate Rows : 0\n","output_type":"stream"}],"execution_count":8},{"cell_type":"markdown","source":"# **Step 7 — Data Cleaning**","metadata":{}},{"cell_type":"code","source":"# Remove Postal Code column\ndf.drop(columns=[\"Postal Code\"], inplace=True)\n\nprint(\"Data cleaning completed successfully.\")\nprint(f\"New Shape: {df.shape}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T05:22:43.34821Z","iopub.execute_input":"2026-07-06T05:22:43.34856Z","iopub.status.idle":"2026-07-06T05:22:43.368422Z","shell.execute_reply.started":"2026-07-06T05:22:43.34853Z","shell.execute_reply":"2026-07-06T05:22:43.367416Z"}},"outputs":[{"name":"stdout","text":"Data cleaning completed successfully.\nNew Shape: (51290, 23)\n","output_type":"stream"}],"execution_count":15},{"cell_type":"markdown","source":"# **Step 8 — Feature Engineering**","metadata":{}},{"cell_type":"code","source":"# Order Year\ndf[\"Year\"] = df[\"Order Date\"].dt.year\n\n# Order Month\ndf[\"Month\"] = df[\"Order Date\"].dt.month_name()\n\n# Order Quarter\ndf[\"Quarter\"] = df[\"Order Date\"].dt.quarter\n\nprint(\"Feature engineering completed successfully.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T05:23:30.675786Z","iopub.execute_input":"2026-07-06T05:23:30.676156Z","iopub.status.idle":"2026-07-06T05:23:30.706198Z","shell.execute_reply.started":"2026-07-06T05:23:30.676126Z","shell.execute_reply":"2026-07-06T05:23:30.705278Z"}},"outputs":[{"name":"stdout","text":"Feature engineering completed successfully.\n","output_type":"stream"}],"execution_count":16},{"cell_type":"markdown","source":"# **Step 9 — Business KPIs**\nKey Performance Indicator","metadata":{}},{"cell_type":"code","source":"total_sales = df[\"Sales\"].sum()\ntotal_profit = df[\"Profit\"].sum()\ntotal_orders = df[\"Order ID\"].nunique()\ntotal_customers = df[\"Customer ID\"].nunique()\n\nprint(f\"Total Sales     : ${total_sales:,.2f}\")\nprint(f\"Total Profit    : ${total_profit:,.2f}\")\nprint(f\"Total Orders    : {total_orders:,}\")\nprint(f\"Total Customers : {total_customers:,}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T05:24:27.536259Z","iopub.execute_input":"2026-07-06T05:24:27.536574Z","iopub.status.idle":"2026-07-06T05:24:27.557855Z","shell.execute_reply.started":"2026-07-06T05:24:27.536549Z","shell.execute_reply":"2026-07-06T05:24:27.5569Z"}},"outputs":[{"name":"stdout","text":"Total Sales     : $12,642,501.91\nTotal Profit    : $1,467,457.29\nTotal Orders    : 25,035\nTotal Customers : 1,590\n","output_type":"stream"}],"execution_count":17},{"cell_type":"markdown","source":"# **Step 10 — Monthly Sales Trend**","metadata":{}},{"cell_type":"code","source":"\n# Monthly Sales Trend\n\n\nmonthly_sales = (\n    df.groupby([\"Year\", \"Month\"])[\"Sales\"]\n      .sum()\n      .reset_index()\n)\n\n# Correct month order\nmonth_order = [\n    \"January\", \"February\", \"March\", \"April\",\n    \"May\", \"June\", \"July\", \"August\",\n    \"September\", \"October\", \"November\", \"December\"\n]\n\nmonthly_sales[\"Month\"] = pd.Categorical(\n    monthly_sales[\"Month\"],\n    categories=month_order,\n    ordered=True\n)\n\nmonthly_sales = monthly_sales.sort_values([\"Year\", \"Month\"])\n\nplt.figure(figsize=(14,5))\n\nplt.plot(\n    range(len(monthly_sales)),\n    monthly_sales[\"Sales\"],\n    marker=\"o\"\n)\n\nplt.xticks(\n    range(len(monthly_sales)),\n    monthly_sales[\"Year\"].astype(str) + \"-\" + monthly_sales[\"Month\"].str[:3],\n    rotation=45\n)\n\nplt.title(\"Monthly Sales Trend\")\nplt.xlabel(\"Month\")\nplt.ylabel(\"Sales\")\n\nplt.grid(alpha=0.3)\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-06T05:26:33.802125Z","iopub.execute_input":"2026-07-06T05:26:33.802552Z","iopub.status.idle":"2026-07-06T05:26:34.332731Z","shell.execute_reply.started":"2026-07-06T05:26:33.802513Z","shell.execute_reply":"2026-07-06T05:26:34.331809Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x500 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":18}]}